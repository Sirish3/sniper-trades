# Copy to .env and fill in — same Alpaca keys used by the main React app
# (see the root .env.local's VITE_ALPACA_KEY_ID / VITE_ALPACA_SECRET_KEY).
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=

# Paper-trading endpoint is fine here — /v2/assets (the universe listing)
# is account metadata, not real order flow, so paper vs. live doesn't matter.
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets/v2/stocks

# Postgres (Neon) — required as of the Chart Patterns feature (chart_setups
# table). Same instance the other two Python services use.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Optional — server-side Claude calls for the daily pattern-scan job's
# batched writeup step (pattern_scan.py). Different key slot from the
# browser's VITE_ANTHROPIC_API_KEY; if unset, detected setups just get a
# templated description instead of a Claude-drafted one, nothing breaks.
ANTHROPIC_API_KEY=

# Server-side Finnhub calls for the Fair Value tab (fair_value.py,
# finnhub_client.py) — financial statements, basic metrics, analyst
# recommendation trend. Different key slot from the browser's
# VITE_FINNHUB_API_KEY (each service owns its own copy of third-party
# credentials — see CLAUDE.md). If unset, fair-value requests degrade to
# Alpaca/Finviz-only data with the relevant sections marked unavailable,
# nothing breaks.
FINNHUB_API_KEY=
