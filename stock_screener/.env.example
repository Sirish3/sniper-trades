# Copy to .env and fill in — same keys used by the main React app
# (see the root .env.local's VITE_ALPACA_KEY_ID / VITE_ALPACA_SECRET_KEY /
# VITE_FINNHUB_API_KEY).
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=
ALPACA_DATA_URL=https://data.alpaca.markets/v2/stocks

# Fundamentals (market cap, P/E) — Finnhub's /stock/metric endpoint, free
# tier is 60 requests/min.
FINNHUB_API_KEY=

# Postgres (Neon) — same instance backend/ uses (see backend/.env's
# DATABASE_URL). Required; no local SQLite fallback.
DATABASE_URL=
