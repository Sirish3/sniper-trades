# Copy this file to .env and fill in real values. Never commit .env.

# Portfolio sizing
PORTFOLIO_SIZE=100000

# Database — defaults to a local SQLite file under backend/data/ if unset.
# For Postgres (e.g. a free Render/Supabase/Neon instance), set:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Email alerts via Resend's HTTP API (not Gmail SMTP — Render blocks
# outbound SMTP on all plans). Get a key at https://resend.com/api-keys.
RESEND_API_KEY=
# Optional — defaults to Resend's shared sandbox sender, which only
# delivers to the email address that owns the Resend account. Set this
# to an address on your own verified domain to send to anyone else.
RESEND_FROM_EMAIL=
ALERT_TO_EMAIL=

# Flask
PORT=8000
