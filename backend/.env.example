# Copy this file to .env and fill in real values. Never commit .env.

# Portfolio sizing
PORTFOLIO_SIZE=100000

# Database — defaults to a local SQLite file under backend/data/ if unset.
# For Postgres (e.g. a free Render/Supabase/Neon instance), set:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Email alerts via Gmail SMTP
# EMAIL_APP_PASSWORD must be a Gmail "app password", not your normal
# password — generate one at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification enabled on the Google account first).
EMAIL_ADDRESS=
EMAIL_APP_PASSWORD=
ALERT_TO_EMAIL=

# Flask
PORT=8000
