# Secrets and Python virtualenvs — catch-all in case a subdirectory's own
# .gitignore misses one; every .env here is a real credential (Neon DB
# password, Gmail app password, trading API keys), never commit any of them.
.env
venv/
__pycache__/
*.pyc

