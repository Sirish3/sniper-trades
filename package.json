{
  "name": "sniper-trades",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:swing": "cd swing_scanner && venv\\Scripts\\python.exe api.py",
    "dev:screener": "cd stock_screener && venv\\Scripts\\python.exe api.py",
    "dev:all": "concurrently -n vite,swing,screener -c blue,green,yellow \"npm run dev\" \"npm run dev:swing\" \"npm run dev:screener\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "eslint": "^9.13.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.9"
  }
}
